	month = jun,
	year = {2024},
	pages = {2543--2604},
	file = {Full Text:C\:\\Users\\sophi\\Zotero\\storage\\9V8HPKVI\\Tian et al. - 2024 - Global nitrous oxide budget (1980–2020).pdf:application/pdf},
}

